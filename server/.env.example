# Copy this file to ".env" and fill in your real values. Never commit the real .env.

# Azure SQL connection
DB_SERVER=your-server.database.windows.net
DB_NAME=serendib_erp
DB_USER=your-sql-admin
DB_PASSWORD=your-strong-password

# Auth
JWT_SECRET=change-this-to-a-long-random-string

# The admin login the server creates on first start (if no users exist)
ADMIN_EMAIL=admin@serendib.lk
ADMIN_PASSWORD=admin123
ADMIN_NAME=Serendib Admin

# Server port (Azure sets this automatically in the cloud)
PORT=4000
